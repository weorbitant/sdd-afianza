{"nodes": [{"id": "plans_2026_05_08_entra_plan_entra_auth_plan", "label": "Entra Auth Portal Cliente Plan (2026-05-08)", "file_type": "document", "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": null, "source_url": null, "captured_at": "2026-05-08", "author": null, "contributor": null}, {"id": "plans_2026_05_08_entra_plan_external_id_strategy", "label": "ExternalIDStrategy (af-nest-module-auth)", "file_type": "concept", "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U1 section", "source_url": null, "captured_at": "2026-05-08", "author": null, "contributor": null, "rationale": "Extends af-nest-module-auth with ExternalID passport strategy. Uses passport-jwt+jwks-rsa (not jose, which is ESM-only). Conditional registration in forAsyncRoot prevents crash when tenantId not provided. useClaimsOnly flag prevents silent fallback that would open privilege escalation surface."}, {"id": "plans_2026_05_08_entra_plan_company_isolation_service", "label": "CompanyIsolationService", "file_type": "concept", "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U2 section", "source_url": null, "captured_at": "2026-05-08", "author": null, "contributor": null, "rationale": "Request-scoped service validating X-Active-Company header against companyIds array from token. Strict includes() comparison prevents CSV injection and prefix-match attacks. Incompatible with AMQP consumers (no HTTP context)."}, {"id": "plans_2026_05_08_entra_plan_multi_issuer_guard", "label": "MultiIssuerGuard", "file_type": "concept", "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U4 section", "source_url": null, "captured_at": "2026-05-08", "author": null, "contributor": null, "rationale": "Routes to correct guard by peeking iss claim without verifying signature. Uses startsWith not includes to prevent evil.com/ciamlogin.com.phish bypass. Has 8KB cap, 3-part JWS check, alg allow-list before decode."}, {"id": "plans_2026_05_08_entra_plan_azure_ad_strategy_fix", "label": "AzureADStrategy Issuer v2 Fix", "file_type": "concept", "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U5 section", "source_url": null, "captured_at": "2026-05-08", "author": null, "contributor": null, "rationale": "Migrates from hardcoded STS v1 issuer (sts.windows.net) to v2 (login.microsoftonline.com). acceptLegacyV1Tokens: true during transition absorbs cached MSAL tokens. Pre-flight F8 blocks deploy until accessTokenAcceptedVersion: 2 is confirmed."}], "edges": [{"source": "plans_2026_05_08_entra_plan_entra_auth_plan", "target": "brainstorms_2026_05_08_entra_multi_app_auth_requirements_entra_multi_app_auth", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "origin field in frontmatter", "weight": 1.0}, {"source": "plans_2026_05_08_entra_plan_entra_auth_plan", "target": "plans_2026_05_08_entra_plan_external_id_strategy", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U1 section", "weight": 1.0}, {"source": "plans_2026_05_08_entra_plan_entra_auth_plan", "target": "plans_2026_05_08_entra_plan_company_isolation_service", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U2 section", "weight": 1.0}, {"source": "plans_2026_05_08_entra_plan_entra_auth_plan", "target": "plans_2026_05_08_entra_plan_multi_issuer_guard", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U4 section", "weight": 1.0}, {"source": "plans_2026_05_08_entra_plan_entra_auth_plan", "target": "plans_2026_05_08_entra_plan_azure_ad_strategy_fix", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U5 section", "weight": 1.0}, {"source": "plans_2026_05_08_entra_plan_external_id_strategy", "target": "memories_core_af_nest_module_auth", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U1 files section", "weight": 1.0}, {"source": "plans_2026_05_08_entra_plan_company_isolation_service", "target": "memories_core_pc_service_portalcliente_api", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U2 files section", "weight": 1.0}, {"source": "plans_2026_05_08_entra_plan_external_id_strategy", "target": "brainstorms_2026_05_08_entra_external_id_tenant", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U1 approach \u2014 issuer format", "weight": 1.0}, {"source": "plans_2026_05_08_entra_plan_external_id_strategy", "target": "brainstorms_2026_05_08_entra_extension_company_ids", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/plans/2026-05-08-001-feat-entra-auth-portal-cliente-plan.md", "source_location": "U1 approach \u2014 companyIdsClaimKey", "weight": 1.0}], "hyperedges": [{"id": "entra_auth_portal_cliente_flow", "label": "Entra External ID Auth Flow for Portal Cliente", "nodes": ["plans_2026_05_08_entra_plan_external_id_strategy", "plans_2026_05_19_company_isolation_gu